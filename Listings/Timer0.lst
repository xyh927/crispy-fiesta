   1          #include <REGX52.H>
   2          
   3          /**
   4            * @brief      定时器0初始化，1毫秒@11.0592MHz
   5            * @param  无
   6            * @retval 无
   7            */
   8          void Timer0_Init(void)
   9          {
  10   1              TMOD&=0xF0;     //设置定时器模式（高四位不变，低四位清零）
  11   1              TMOD|=0x01;     //设置定时器模式（通过低四位设为“定时器0工作方式1”的模式）
  12   1              TL0=0x00;       //设置定时初值，定时10ms
  13   1              TH0=0xDC;       //设置定时初值，定时10ms
  14   1              TF0=0;  //清除TF0标志
  15   1              TR0=1;  //定时器0开始计时
  16   1              ET0=1;  //打开定时器0中断允许
  17   1              EA=1;   //打开总中断
  18   1              PT0=0;  //当PT0=0时，定时器0为低优先级，当PT0=1时，定时器0为高优先级
  19   1      }
  20          
