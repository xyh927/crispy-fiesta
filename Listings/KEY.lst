  14            */
  15          unsigned char Key(void)
  16          {
  17   1              unsigned char KeyTemp=0;
  18   1              KeyTemp=KeyNumber;
  19   1              KeyNumber=0;    //主程序中获取键码值之后键码值清零，在下一次定时器扫描按键之前再次获取键码值，一定会返回0
  20   1              return KeyTemp;
  21   1      }
  22          
  23          /**
  24            * @brief  获取当前按键的状态，无消抖及松手检测
  25            * @param  无
  26            * @retval 按下的按键，范围：0~4，无按键按下时返回值为0
  27            */
  28          unsigned char Key_GetState()
  29          {
  30   1              unsigned char KeyValue=0;
  31   1              
  32   1              if(Key1==0){KeyValue=1;}
  33   1              if(Key2==0){KeyValue=2;}
  34   1              if(Key3==0){KeyValue=3;}
  35   1              if(Key4==0){KeyValue=4;}
  36   1      
  37   1              return KeyValue;
  38   1      }
