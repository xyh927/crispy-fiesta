  40          
  41          /**
  42            * @brief  按键驱动函数，在中断中调用
  43            * @param  无
  44            * @retval 无
  45            */
  46          void Key_Loop(void)
  47          {
  48   1              static unsigned char NowState,LastState;
  49   1              LastState=NowState;     //按键状态更新
  50   1              NowState=Key_GetState();        //获取当前按键状态
  51   1              
  52   1              //如果上个时间点按键未按下，这个时间点按键按下，则是按下瞬间
  53   1              if(LastState==0)
  54   1              {
C51 COMPILER V9.54   KEY                                                                   04/12/2026 16:55:13 PAGE 2   

  55   2                      switch(NowState)
