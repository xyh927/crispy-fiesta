  79          /**
  80            * @brief  DS1302设置时间，调用之后，DS1302_Time数组的数字会被设置到DS1302中
  81            * @param  无
  82            * @retval 无
  83            */
  84          void DS1302_SetTime(void)
  85          {
  86   1              unsigned char i;
  87   1              DS1302_WriteByte(DS1302_WP,0x00);       //设置前把关闭写保护
  88   1              for(i=0;i<7;i++)        //依次写入：年，月，日，时，分，秒，星期
  89   1              {
  90   2                      DS1302_WriteByte(DS1302_WriteAddress[i],DS1302_Time[i]/10*16+DS1302_Time[i]%10);        //十进制转换为BCD码
  91   2              }
  92   1              DS1302_WriteByte(DS1302_WP,0x80);       //设置后开启写保护
  93   1      }
  94          
  95          /**
  96            * @brief  DS1302读取时间，调用之后，DS1302中的数据会被读取到DS1302_Time数组中
  97            * @param  无
  98            * @retval 无
  99            */
 100          void DS1302_ReadTime(void)
 101          {
 102   1              unsigned char Temp,i;
 103   1              for(i=0;i<7;i++)        //依次读取：年，月，日，时，分，秒，星期
 104   1              {
 105   2                      Temp=DS1302_ReadByte(DS1302_ReadAddress[i]);
 106   2                      DS1302_Time[i]=Temp/16*10+Temp%16;//BCD码转十进制后读取
 107   2              }
 108   1      }


