  17          /**
  18            * @brief  DS1302初始化
  19            * @param  无
  20            * @retval 无
  21            */
  22          void DS1302_Init(void)
  23          {
  24   1              DS1302_CE=0;
  25   1              DS1302_SCLK=0;
  26   1      }
  27          
  28          /**
  29            * @brief  DS1302写一个字节
  30            * @param  Command 命令字/地址
  31            * @param  Data 要写入的数据
  32            * @retval 无
  33            */
  34          void DS1302_WriteByte(unsigned char Command,unsigned char Data)
  35          {
  36   1              unsigned char i;
  37   1              DS1302_CE=1;
  38   1              for(i=0;i<8;i++)        //循环8次，每次写1位，先写低位再写高位
  39   1              {
  40   2                      DS1302_IO=Command&(0x01<<i);    //“&与”，用于清零
  41   2                      DS1302_SCLK=1;  //SCLK置1后立即置0，该时序操作需考虑时钟芯片是否可承受这个时钟的最快频率
  42   2                      DS1302_SCLK=0;  //由于单片机没有这么快的频率，故可不加延时
  43   2              }
  44   1              for(i=0;i<8;i++)
  45   1              {
  46   2                      DS1302_IO=Data&(0x01<<i);
  47   2                      DS1302_SCLK=1;  //CLK由低到高产生一个上升沿，从而写入数据
  48   2                      DS1302_SCLK=0;
  49   2              }
  50   1              DS1302_CE=0;
  51   1      }
  52          
  53          /**
  54            * @brief  DS1302读一个字节
C51 COMPILER V9.54   DS1302                                                                05/19/2026 14:10:31 PAGE 2   

  55            * @param  Command     命令字/地址
  56            * @retval Data        读出的数据
  57            */
  58          unsigned char DS1302_ReadByte(unsigned char Command)
  59          {
  60   1              unsigned char i,Data=0x00;
  61   1              DS1302_CE=1;
  62   1              for(i=0;i<8;i++)
  63   1              {
  64   2                      DS1302_IO=Command&(0x01<<i);
  65   2                      DS1302_SCLK=0;
  66   2                      DS1302_SCLK=1;
  67   2              }
  68   1              for(i=0;i<8;i++)
  69   1              {
  70   2                      DS1302_SCLK=1;
  71   2                      DS1302_SCLK=0;  //要先1后0，否则全都是65
  72   2                      if(DS1302_IO){Data|=(0x01<<i);}
  73   2              }
  74   1              DS1302_CE=0;
  75   1              DS1302_IO=0;    //读取后将IO设置为0，否则读出的数据会出错
  76   1              return Data;
  77   1      }
