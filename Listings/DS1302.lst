  10          //DS1302写入时间的地址：年，月，日，时，分，秒，星期
  11          unsigned char code DS1302_WriteAddress[7]={0x8c,0x88,0x86,0x84,0x82,0x80,0x8a,};
  12          //DS1302读取时间的地址：年，月，日，时，分，秒，星期
  13          unsigned char code DS1302_ReadAddress[7]={0x8d,0x89,0x87,0x85,0x83,0x81,0x8b,};
  14          //时间数组：年，月，日，时，分，秒，星期
  15          char DS1302_Time[]={24,10,30,9,13,53,3};        //时间设置的初始值
