  14          unsigned int humi_low=40;        // 湿度下限(默认40%)
  15          
  16          // 继电器初始化
  17          void Relay_Init(void)
  18          {
  19   1          RELAY_HEAT=1;
  20   1          RELAY_COOL=1;
  21   1          RELAY_HUMI=1;
  22   1          RELAY_UV=1;
  23   1      }
  24          
  25          
  26          void Relay_Control(unsigned int temp, unsigned int humi)
  27          {
  28   1          /* ---------- 制冷（RELAY_COOL=0 吸合）---------- */
  29   1          if(temp > temp_high + 1 || humi > humi_high + 2) {
  30   2              RELAY_COOL = 0;           // 温度过高或湿度过高 → 强制开启
  31   2          }
  32   1          else if(temp < temp_high - 1) {
  33   2              RELAY_COOL = 1;           // 温度已降到安全线以下 → 允许关闭
  34   2          }
  35   1          /* 滞回带：temp 在 [high-1, high+1] 之间时，不操作，保持原状态 */
  36   1      
  37   1          /* ---------- 加热（RELAY_HEAT=0 吸合）---------- */
  38   1          if(temp < temp_low - 1) {
  39   2              RELAY_HEAT = 0;           // 温度过低 → 强制开启
  40   2          }
  41   1          else if(temp > temp_low + 1) {
  42   2              RELAY_HEAT = 1;           // 温度已回升 → 允许关闭
  43   2          }
  44   1          /* 中间态保持原状态（原代码已如此，无需改动） */
  45   1      
  46   1          /* ---------- 加湿（RELAY_HUMI=0 吸合）---------- */
  47   1          if(humi < humi_low - 2) {
  48   2              RELAY_HUMI = 0;           // 湿度过低 → 强制开启
  49   2          }
  50   1          else if(humi > humi_low + 2) {
  51   2              RELAY_HUMI = 1;           // 湿度已回升 → 允许关闭
  52   2          }
  53   1          /* 滞回带：humi 在 [low-2, low+2] 之间时，不操作，保持原状态 */
  54   1      }
